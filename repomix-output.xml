<file path=".github/workflows/build.yml">
name: Build and Test

on:
  workflow_dispatch:
  pull_request:
    branches: [ develop, main ]

jobs:
  build:
    name: Build and analyze
    runs-on: ubuntu-latest
    permissions:
      contents: read
      checks: write
      pull-requests: write

    steps:
      # Step 1: Code aus dem Repository holen
      # fetch-depth: 0 deaktiviert Shallow Clones für bessere SonarQube Analyse
      - name: Checkout code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0

      # Step 2: Java 21 installieren auf der frischen VM
      - name: Set up JDK 21
        uses: actions/setup-java@v4
        with:
          java-version: '21'
          distribution: 'temurin'

      # Step 3: SonarQube Cache (spart Zeit beim nächsten Run)
      - name: Cache SonarQube packages
        uses: actions/cache@v4
        with:
          path: ~/.sonar/cache
          key: ${{ runner.os }}-sonar
          restore-keys: ${{ runner.os }}-sonar

      # Step 4: Maven Dependencies cachen (spart Zeit beim nächsten Run)
      - name: Cache Maven packages
        uses: actions/cache@v4
        with:
          path: ~/.m2
          key: ${{ runner.os }}-m2-${{ hashFiles('**/pom.xml') }}
          restore-keys: ${{ runner.os }}-m2

      # Step 5: Projekt bauen, Tests ausführen und SonarQube Analyse starten
      # mvn verify führt aus: compile -> test -> checkstyle -> jacoco
      # sonar-maven-plugin schickt die Ergebnisse an den SonarQube Server
      - name: Build, Test and Analyze
        env:
          SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}
          SONAR_HOST_URL: ${{ secrets.SONAR_HOST_URL }}
        run: mvn -B verify org.sonarsource.scanner.maven:sonar-maven-plugin:sonar
          -Dsonar.projectKey=FitnessTracker
          -Dsonar.projectName='FitnessTracker'

      # Step 6: JaCoCo Coverage Report als Artefakt hochladen
      # retention-days: 7 → Report wird 7 Tage gespeichert
      - name: Upload coverage report
        uses: actions/upload-artifact@v4
        with:
          name: jacoco-coverage-report
          path: |
            storage/target/site/jacoco/
            api/target/site/jacoco/
          retention-days: 7

      # Step 7: JAR als Artefakt hochladen
      # beide Module werden hochgeladen (storage + api)
      - name: Upload JAR artifact
        uses: actions/upload-artifact@v4
        with:
          name: fitness-tracker-jar
          path: |
            storage/target/*.jar
            api/target/*.jar
          retention-days: 7

      # Step 8: Docker Image bauen
      # nutzt das Dockerfile im Root des Projekts
      # Tag: dockerhub-username/fitness-tracker:latest
      - name: Build Docker Image
        run: |
          VERSION=${{ github.sha }}  # Commit SHA als Version
          docker build -t mehdi2005/fitness-tracker:$VERSION .
          docker build -t mehdi2005/fitness-tracker:latest .
      # Step 9: Docker Hub Login
      # nutzt Secrets aus GitHub Repository Settings
      # DOCKER_USERNAME → dein Docker Hub Username
      # DOCKER_TOKEN → Docker Hub Access Token (nicht Passwort!)
      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_TOKEN }}

      # Step 10: Docker Image zu Docker Hub pushen
      # Image ist dann öffentlich verfügbar auf Docker Hub
      # andere können es mit: docker pull username/fitness-tracker:latest laden
      - name: Push Docker Image
        run: docker push ${{ secrets.DOCKER_USERNAME }}/fitness-tracker:latest
</file>

